# ============================================
# 미국 재무제표 분석 봇 - 환경 변수 설정
# 이 파일을 복사해서 .env 파일로 만들어 사용하세요
# cp .env.example .env
# ============================================

# ============================================
# [필수] LLM 설정 - 아래 중 하나 선택
# ============================================

# --- Option A: OpenAI 사용 ---
# LLM_PROVIDER=openai
# CHAT_MODEL=gpt-4.1-mini
# REPORT_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=sk-your-openai-api-key

# --- Option B: Gemini 사용 (무료) ---
# LLM_PROVIDER=gemini
# CHAT_MODEL=gemini-2.5-flash
# REPORT_MODEL=gemini-2.5-flash
# GOOGLE_API_KEY=your-google-api-key

# 공통 설정
EMBEDDING_MODEL=text-embedding-3-small
TEMPERATURE=0.1
MAX_TOKENS=4096

# ============================================
# [필수] OpenAI API (임베딩 전용 - 모든 팀원 필요)
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================
# [필수] Supabase Database
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# ============================================
# [필수] Neo4j Graph Database (기업 관계)
# ============================================
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=your-neo4j-user
NEO4J_PASSWORD=your-neo4j-password

# ============================================
# [선택] 외부 API
# ============================================

# Finnhub API (실시간 주가, 뉴스)
# https://finnhub.io 에서 발급
FINNHUB_API_KEY=your-finnhub-api-key

# SEC EDGAR API (데이터 수집용)
SEC_API_USER_AGENT=your_email@example.com

# Tavily API (웹 검색)
TAVILY_API_KEY=your-tavily-api-key

# ============================================
# [선택] LangSmith 트레이싱
# ============================================
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=SKN22-3rd-4Team

# ============================================
# 앱 설정
# ============================================
DEBUG=False
LOG_LEVEL=INFO
MAX_WORKERS=4
